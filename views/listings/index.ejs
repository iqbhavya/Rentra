<% layout("layouts/boilerplate") %>

<div id="filters-wrapper">
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
        <div id="filters">
            <% 
            const categoriesList = [
                { name: "All", icon: "fa-solid fa-globe" },
                { name: "Trending", icon: "fa-solid fa-fire" },
                { name: "Rooms", icon: "fa-solid fa-bed" },
                { name: "Mountains", icon: "fa-solid fa-mountain" },
                { name: "Beach", icon: "fa-solid fa-umbrella-beach" },
                { name: "City", icon: "fa-solid fa-city" },
                { name: "Camping", icon: "fa-solid fa-campground" },
                { name: "Homes", icon: "fa-solid fa-house" },
                { name: "Pool", icon: "fa-solid fa-person-swimming" },
                { name: "Hotels", icon: "fa-solid fa-hotel" },
                { name: "Luxury", icon: "fa-solid fa-champagne-glasses" }
            ];
            %>
            <% for(let cat of categoriesList) { %>
                <div class="filter <%= (cat.name === 'All' && !activeCategory) || activeCategory === cat.name ? 'active' : '' %>" 
                     onclick="window.location.href='<%= cat.name === 'All' ? '/listings' : '/listings?category=' + cat.name %>'">
                    <div><i class="<%= cat.icon %>"></i></div>
                    <p><%= cat.name %></p>
                </div>
            <% } %>
        </div>
    <!-- Removed this for now -->
        <!-- <div class="tax-toggle">
            <span class="tax-label">Display total after taxes</span>
            <div class="form-check form-switch m-0 p-0 d-flex align-items-center">
                <input class="form-check-input m-0" type="checkbox" role="switch" id="switchCheckDefault">
            </div>
        </div> -->
    </div>
</div>

<div class="listings-grid">
    <% for(let listing of listings) { %>
        <a class="listing-links" href="/listings/<%= listing._id %>">
            <div class="card listing-card">
                <div class="card-img-wrapper">
                    <img src="<%= listing.image.url %>" class="card-img-top" alt="<%= listing.title %> - property listing image">
                    <button class="wishlist-heart" type="button" onclick="event.preventDefault(); this.classList.toggle('active');">
                        <i class="fa-solid fa-heart"></i>
                    </button>
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start gap-2">
                        <h5 class="listing-title"><%= listing.title %></h5>
                        <% 
                        let totalRating = 0;
                        let validReviewsCount = 0;
                        let avgRating = "New";
                        if (listing.reviews && listing.reviews.length > 0) {
                            for (let rev of listing.reviews) {
                                if (rev && typeof rev.rating === "number") {
                                    totalRating += rev.rating;
                                    validReviewsCount++;
                                }
                            }
                            if (validReviewsCount > 0) {
                                avgRating = (totalRating / validReviewsCount).toFixed(1);
                            }
                        }
                        %>
                        <span class="text-nowrap" style="font-size: 0.85rem; font-weight: 600;">
                            <i class="fa-solid fa-star <%= avgRating === 'New' ? 'text-muted' : 'text-warning' %>"></i> <%= avgRating %>
                        </span>
                    </div>
                    <p class="listing-location"><%= listing.location %>, <%= listing.country %></p>
                    <p class="listing-price-row">
                        <b>&#8377; <%= listing.price.toLocaleString("en-IN") %></b> / night
                        <span class="tax-info">&nbsp;&nbsp;+18% GST</span>
                    </p>
                </div>
            </div>
        </a>
    <% } %>
</div>

<script>
    // Tax Toggle switch script
    let taxSwitch = document.getElementById("switchCheckDefault");
    taxSwitch.addEventListener("click", () => {
        let taxInfo = document.getElementsByClassName("tax-info");
        let toggleContainer = document.querySelector(".tax-toggle");
        
        // Visual toggle container active class
        toggleContainer.classList.toggle("active");
        
        for (let info of taxInfo) {
            if (info.style.display !== "inline") {
                info.style.display = "inline";
                info.style.opacity = "1";
            } else {
                info.style.display = "none";
                info.style.opacity = "0";
            }
        }
    });
</script>