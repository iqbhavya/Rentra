<% layout("layouts/boilerplate") %>

<div class="row">
    <div class="col-12">
        <div class="form-card">
            <h1 class="form-title">Edit Listing</h1>
            
            <form method="POST" action="/listings/<%= listing._id %>?_method=PATCH" novalidate class="needs-validation" enctype="multipart/form-data">
                
                <div class="mb-3">
                    <label for="title" class="form-label">Property Title</label>
                    <input type="text" name="listing[title]" id="title" value="<%= listing.title %>" required class="form-control">
                    <div class="invalid-feedback">Please enter a title.</div>
                </div>

                <div class="mb-3">
                    <label for="description" class="form-label">Description</label>
                    <textarea name="listing[description]" id="description" cols="30" rows="4" required class="form-control"><%= listing.description %></textarea>
                    <div class="invalid-feedback">Please enter a short description.</div>
                </div>

                <div class="mb-3">
                    <label class="form-label d-block">Original Listing Image</label>
                    <div class="original-img-preview">
                        <img src="<%= listing.image.url %>" alt="Original Listing Image" style="max-width: 100%; max-height: 180px; object-fit: cover; display: block;">
                    </div>
                </div>

                <div class="mb-3">
                    <label for="image" class="form-label">Update Image</label>
                    <input name="listing[image]" id="image" type="file" class="form-control">
                    <small class="text-muted">Leave empty to keep the original image</small>
                </div>

                <div class="row">
                    <div class="mb-3 col-md-4">
                        <label for="price" class="form-label">Price per night (&#8377;)</label>
                        <input name="listing[price]" id="price" value="<%= listing.price %>" type="number" class="form-control" required>
                        <div class="invalid-feedback">Please enter the price.</div>
                    </div>

                    <div class="mb-3 col-md-8">
                        <label for="country" class="form-label">Country</label>
                        <input type="text" name="listing[country]" id="country" value="<%= listing.country %>" class="form-control" required>
                        <div class="invalid-feedback">Please enter the country.</div>
                    </div>
                </div>

                <div class="mb-4">
                    <label for="location" class="form-label">Location</label>
                    <input type="text" name="listing[location]" id="location" value="<%= listing.location %>" class="form-control" required>
                    <div class="invalid-feedback">Please enter the location.</div>
                </div>

                <button type="submit" class="btn btn-form-action">Update Property</button>
            </form>
        </div>
    </div>
</div>
