<% layout("layouts/boilerplate") %>

<div class="row">
    <div class="col-12">
        <div class="form-card text-center" style="max-width: 500px; margin-top: 4rem;">
            <div class="text-danger mb-3">
                <i class="fa-solid fa-triangle-exclamation" style="font-size: 3rem;"></i>
            </div>
            <h1 class="form-title text-danger mb-2">Something went wrong!</h1>
            <p class="text-muted mb-4"><%= err.message %></p>
            <a href="/listings" class="btn btn-form-action" style="background: var(--text-main) !important; color: white !important;">Back to Home</a>
        </div>
    </div>
</div>